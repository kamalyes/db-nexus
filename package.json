{
  "name": "db-nexus",
  "displayName": "DB Nexus",
  "description": "A multi-database workbench for VS Code with schema browsing, query execution, data editing, and AI-ready architecture.",
  "version": "0.1.0",
  "publisher": "kamalyes",
  "repository": {
    "type": "git",
    "url": "https://github.com/kamalyes/db-nexus"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Data Science",
    "Other"
  ],
  "keywords": [
    "database",
    "sql",
    "postgresql",
    "mysql",
    "sqlite",
    "mongodb",
    "redis",
    "duckdb",
    "vscode"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:dbNexus.connections",
    "onCommand:dbNexus.addConnection",
    "onCommand:dbNexus.runQuery"
  ],
  "main": "./dist/extension.js",
