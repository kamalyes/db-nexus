        "dbNexus.defaultQueryLimit": {
          "type": "number",
          "default": 500,
          "minimum": 1,
          "maximum": 10000,
          "description": "%dbNexus.defaultQueryLimit.description%"
        },
        "dbNexus.enablePreviewDrivers": {
          "type": "boolean",
          "default": true,
          "description": "%dbNexus.enablePreviewDrivers.description%"
        },
        "dbNexus.displayLanguage": {
          "type": "string",
          "default": "",
          "enum": [
            "",
            "en",
            "zh-CN"
          ],
          "enumItemLabels": [
            "%dbNexus.displayLanguage.auto%",
            "%dbNexus.displayLanguage.english%",
            "%dbNexus.displayLanguage.zhCN%"
          ],
          "description": "%dbNexus.displayLanguage.description%"
        }
      }
    }
  },
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "lint": "tsc --noEmit",
    "package": "npm run build && vsce package"
  },
  "dependencies": {
    "duckdb": "^1.1.0",
    "mysql2": "^3.9.0",
    "pg": "^8.11.0",
    "sql.js": "^1.10.0"
  },
  "devDependencies": {
    "@types/mysql2": "github:types/mysql2",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.10.0",
    "@types/sql.js": "^1.4.11",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.32.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.3.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.0"
  }
}
